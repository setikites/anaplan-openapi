# Anaplan live-test credentials — copy to .env and fill in your values.
# .env is gitignored; never commit real credentials.
# See docs/TESTING.md for full setup instructions.

# ── Authentication ────────────────────────────────────────────────────────────

# Basic auth (fallback when certificate auth is not configured)
ANAPLAN_USERNAME=
ANAPLAN_PASSWORD=

# Certificate auth (preferred over basic auth when both are configured)
ANAPLAN_CA_CERT_PATH=
ANAPLAN_CA_KEY_PATH=
ANAPLAN_CA_KEY_PASSWORD=

# ── OAuth ─────────────────────────────────────────────────────────────────────

ANAPLAN_OAUTH_CLIENT_ID=
ANAPLAN_OAUTH_DEVICE_CLIENT_ID=
ANAPLAN_OAUTH_AUTHCODE_CLIENT_ID=
ANAPLAN_OAUTH_AUTHCODE_CLIENT_SECRET=
ANAPLAN_OAUTH_KEYRING_SERVICE=anaplan-oauth-authcode

# ── Integration API test model ────────────────────────────────────────────────

ANAPLAN_INTEGRATION_WORKSPACE_ID=
ANAPLAN_INTEGRATION_MODEL_ID=

# ── ALM API test model ────────────────────────────────────────────────────────

ANAPLAN_ALM_WORKSPACE_ID=
ANAPLAN_ALM_MODEL_ID=

# ── Exception API ─────────────────────────────────────────────────────────────

ANAPLAN_EXCEPTION_WORKSPACE_GUID=
ANAPLAN_EXCEPTION_USER_GUID=

# ── Miscellaneous ─────────────────────────────────────────────────────────────

# Override the Integration API base URL (default: https://api.anaplan.com)
# ANAPLAN_API_BASE_URL=

# Override the ALM API base URL (default: https://api.anaplan.com/2/0)
# ANAPLAN_ALM_BASE_URL=

ANAPLAN_API_KEY=
