{
  "openapi": "3.0.0",
  "info": {
    "title": "Anaplan SCIM API",
    "version": "1.0.0",
    "description": "Anaplan implementation of SCIM 2.0 (RFC 7644) for user identity management. Supports Users and Anaplan-specific entitlements only; Groups are not implemented."
  },
  "servers": [
    {
      "url": "https://api.anaplan.com/scim/1/0/v2",
      "description": "US1, US2, US5, US7, EU1, EU2, EU4, AP1"
    },
    {
      "url": "https://us9.api.anaplan.com/scim/1/0/v2",
      "description": "US9"
    },
    {
      "url": "https://eu3.api.anaplan.com/scim/1/0/v2",
      "description": "EU3"
    },
    {
      "url": "https://eu5.api.anaplan.com/scim/1/0/v2",
      "description": "EU5"
    },
    {
      "url": "https://gb1.api.anaplan.com/scim/1/0/v2",
      "description": "GB1"
    },
    {
      "url": "https://ca1a.api.anaplan.com/scim/1/0/v2",
      "description": "CA1"
    },
    {
      "url": "https://sg1.api.anaplan.com/scim/1/0/v2",
      "description": "SG1"
    },
    {
      "url": "https://ae1.api.anaplan.com/scim/1/0/v2",
      "description": "AE1"
    },
    {
      "url": "https://in1.api.anaplan.com/scim/1/0/v2",
      "description": "IN1"
    },
    {
      "url": "https://id1.api.anaplan.com/scim/1/0/v2",
      "description": "ID1"
    },
    {
      "url": "https://me1.api.anaplan.com/scim/1/0/v2",
      "description": "ME1"
    },
    {
      "url": "https://au1a.api2.anaplan.com/scim/1/0/v2",
      "description": "AU1"
    }
  ],
  "security": [
    {
      "AnaplanAuthToken": []
    },
    {
      "BearerAuth": []
    },
    {
      "BasicAuth": []
    }
  ],
  "paths": {
    "/Users": {
      "get": {
        "operationId": "listUsers",
        "summary": "List users",
        "description": "Minimum role: User Administrator.\n\nReturns a paginated list of users. Supports SCIM filtering, pagination, and count controls. Maximum 100 users per call.",
        "parameters": [
          {
            "name": "filter",
            "in": "query",
            "description": "SCIM filter expression. The Anaplan implementation supports only a subset; unsupported operators or attributes return 400 with scimType `invalidValue`.\n\n**Operators:** `eq`, `ne`, `pr`, `gt`, `ge`, `lt`, `le`.\n\n**Logical operators / grouping:** `and`, `or`, and precedence grouping with `( )` (including nested groups).\n\n**Filterable attributes:** `userName`, `active`, `id`, `externalId`, and `name` sub-attributes via dot notation (e.g. `name.familyName`).",
            "schema": {
              "type": "string",
              "example": "userName eq \"john@example.com\""
            },
            "examples": {
              "byUserName": {
                "summary": "Match a user by email (userName)",
                "value": "userName eq \"john@example.com\""
              },
              "activeOnly": {
                "summary": "Active users only",
                "value": "active eq true"
              },
              "andGrouped": {
                "summary": "Combine conditions with and + grouping",
                "value": "(userName eq \"john@example.com\") and (active eq true)"
              }
            }
          },
          {
            "name": "startIndex",
            "in": "query",
            "description": "1-based index of the first result in the current set of list results.",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "count",
            "in": "query",
            "description": "Maximum number of results per page. Maximum allowed value is 100.",
            "schema": {
              "type": "integer",
              "default": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A paginated list of users."
          },
          "400": {
            "description": "Invalid filter expression or request."
          },
          "401": {
            "description": "Missing or invalid authentication token."
          },
          "403": {
            "description": "Caller does not have USER_ADMIN role."
          }
        }
      },
      "post": {
        "operationId": "createUser",
        "summary": "Create user",
        "description": "Minimum role: User Administrator.\n\nCreates a new user and assigns Anaplan entitlements. Maximum 50 workspaces per call. SCIM does not support Visiting users.",
        "requestBody": {
          "required": true,
          "content": {
            "application/scim+json": {
              "schema": {
                "$ref": "#/components/schemas/User"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created."
          },
          "400": {
            "description": "Invalid request body or missing required fields."
          },
          "401": {
            "description": "Missing or invalid authentication token."
          },
          "403": {
            "description": "Caller does not have USER_ADMIN role."
          },
          "409": {
            "description": "User already exists (conflict on userName)."
          }
        }
      }
    },
    "/Users/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "description": "Anaplan-assigned hex-32 GUID of the user \u2014 the same value as the Anaplan user ID. From `GET /Users` (`Resources[].id`); if SCIM access is unavailable, the same GUID comes from `GET /users` or `GET /users/me` in the Integration API.",
          "required": true,
          "schema": {
            "type": "string",
            "pattern": "^[0-9a-f]{32}$"
          },
          "example": "8a8b8c8d8e8f1a2b3c4d5e6f78901234"
        }
      ],
      "get": {
        "operationId": "getUser",
        "summary": "Get user",
        "description": "Minimum role: User Administrator.\n\nRetrieves a single user by their Anaplan ID.",
        "responses": {
          "200": {
            "description": "The requested user."
          },
          "401": {
            "description": "Missing or invalid authentication token."
          },
          "403": {
            "description": "Caller does not have USER_ADMIN role."
          },
          "404": {
            "description": "User not found."
          }
        }
      },
      "put": {
        "operationId": "replaceUser",
        "summary": "Replace user",
        "description": "Minimum role: User Administrator.\n\nPerforms a full replacement of a user resource. All mutable attributes must be provided; omitted attributes are cleared.",
        "requestBody": {
          "required": true,
          "content": {
            "application/scim+json": {
              "schema": {
                "$ref": "#/components/schemas/User"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User replaced."
          },
          "400": {
            "description": "Invalid request body."
          },
          "401": {
            "description": "Missing or invalid authentication token."
          },
          "403": {
            "description": "Caller does not have USER_ADMIN role."
          },
          "404": {
            "description": "User not found."
          }
        }
      },
      "patch": {
        "operationId": "patchUser",
        "summary": "Update user",
        "description": "Minimum role: User Administrator.\n\nPerforms a partial update of a user resource using SCIM PatchOp semantics (RFC 7644 \u00a73.5.2).",
        "requestBody": {
          "required": true,
          "content": {
            "application/scim+json": {
              "schema": {
                "$ref": "#/components/schemas/PatchOp"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated."
          },
          "400": {
            "description": "Invalid PatchOp or unsupported operation."
          },
          "401": {
            "description": "Missing or invalid authentication token."
          },
          "403": {
            "description": "Caller does not have USER_ADMIN role."
          },
          "404": {
            "description": "User not found."
          }
        }
      },
      "delete": {
        "operationId": "deleteUser",
        "summary": "Delete user",
        "description": "Minimum role: User Administrator.\n\nDeletes a user by their Anaplan ID. DELETE returns 403 (not 405) when the caller lacks USER_ADMIN role.",
        "responses": {
          "204": {
            "description": "User deleted."
          },
          "401": {
            "description": "Missing or invalid authentication token."
          },
          "403": {
            "description": "Caller does not have USER_ADMIN role."
          },
          "404": {
            "description": "User not found."
          }
        }
      }
    },
    "/ResourceTypes": {
      "get": {
        "operationId": "getResourceTypes",
        "summary": "Get resource types",
        "description": "Minimum role: None.\n\nReturns the SCIM resource types supported by this service provider.",
        "security": [],
        "responses": {
          "200": {
            "description": "List of supported resource types."
          },
          "401": {
            "description": "Missing or invalid authentication token."
          }
        }
      }
    },
    "/Schemas": {
      "get": {
        "operationId": "getSchemas",
        "summary": "Get schemas",
        "description": "Minimum role: None.\n\nReturns the SCIM schema definitions supported by this service provider.",
        "security": [],
        "responses": {
          "200": {
            "description": "List of schema definitions."
          },
          "401": {
            "description": "Missing or invalid authentication token."
          }
        }
      }
    },
    "/ServiceProviderConfig": {
      "get": {
        "operationId": "getServiceProviderConfig",
        "summary": "Get service provider configuration",
        "description": "Minimum role: None.\n\nReturns a description of the service provider's SCIM configuration and capabilities (patch support, bulk, filter, sort, etc.).",
        "security": [],
        "responses": {
          "200": {
            "description": "Service provider configuration."
          },
          "401": {
            "description": "Missing or invalid authentication token."
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "description": "Anaplan SCIM User resource. Implements the SCIM core User schema plus Anaplan-specific entitlements.",
        "required": [
          "userName",
          "name"
        ],
        "properties": {
          "schemas": {
            "type": "array",
            "description": "List of SCIM schema URNs that declare the resource type. For the Anaplan User resource, include `urn:ietf:params:scim:schemas:core:2.0:User`.",
            "items": {
              "type": "string"
            }
          },
          "id": {
            "type": "string",
            "pattern": "^[0-9a-f]{32}$",
            "description": "Anaplan-assigned hex-32 GUID for this user (read-only).",
            "readOnly": true
          },
          "externalId": {
            "type": "string",
            "description": "Unique identifier assigned by the provisioning client. Format is caller-controlled; no pattern constraint."
          },
          "userName": {
            "type": "string",
            "description": "Username of the user. Required and unique (read-only after creation).",
            "readOnly": true
          },
          "name": {
            "type": "object",
            "description": "Components of the user's real name.",
            "required": [
              "familyName",
              "givenName"
            ],
            "properties": {
              "familyName": {
                "type": "string"
              },
              "givenName": {
                "type": "string"
              },
              "formatted": {
                "type": "string",
                "description": "Formatted full name (read-only, generated from givenName + familyName).",
                "readOnly": true
              }
            }
          },
          "displayName": {
            "type": "string",
            "description": "Display name (read-only, generated from givenName + familyName).",
            "readOnly": true
          },
          "active": {
            "type": "boolean",
            "description": "Controls whether the user can log into Anaplan."
          },
          "emails": {
            "type": "array",
            "description": "Email addresses for the user. Only `work` type is supported.",
            "items": {
              "type": "object",
              "properties": {
                "value": {
                  "type": "string",
                  "description": "The email address."
                },
                "type": {
                  "type": "string",
                  "description": "The type of email. Only `work` is supported."
                },
                "primary": {
                  "type": "boolean",
                  "readOnly": true
                }
              }
            }
          },
          "entitlements": {
            "type": "array",
            "description": "Anaplan-specific workspace entitlements for the user. Not a standard SCIM attribute. Maximum 50 workspaces per create call.",
            "items": {
              "type": "object",
              "properties": {
                "value": {
                  "type": "string",
                  "description": "The target resource ID of the entitlement. For `WORKSPACE` type this is a workspace GUID from `GET /workspaces` in the [Integration API](https://help.anaplan.com/integration-api-v20-3107aa54-d12b-4c48-9550-3561c84adbb2) (`workspaces[].id`); for `WORKSPACE_IDS` it is a comma-delimited list of those GUIDs.",
                  "example": "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4"
                },
                "display": {
                  "type": "string",
                  "description": "Human-readable name of the entitlement.",
                  "example": "Sales Planning"
                },
                "type": {
                  "type": "string",
                  "description": "Entitlement grouping format. `WORKSPACE` \u2014 one object per workspace (use this when writing); `WORKSPACE_IDS` \u2014 single object whose `value` is a comma-delimited list of workspace GUIDs; `WORKSPACE_NAMES` \u2014 single object whose `value` is a comma-delimited list of workspace names. Responses typically include all three variants for the same workspace set.",
                  "enum": [
                    "WORKSPACE",
                    "WORKSPACE_IDS",
                    "WORKSPACE_NAMES"
                  ],
                  "readOnly": true
                },
                "primary": {
                  "type": "boolean",
                  "description": "Indicates the primary entitlement. At most one entry may be `true`.",
                  "readOnly": true
                }
              }
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "resourceType": {
                "type": "string"
              },
              "location": {
                "type": "string"
              }
            }
          }
        }
      },
      "PatchOp": {
        "type": "object",
        "description": "SCIM PATCH request body (RFC 7644 \u00a73.5.2).",
        "required": [
          "schemas",
          "Operations"
        ],
        "properties": {
          "schemas": {
            "type": "array",
            "description": "List of SCIM schema URNs declaring the patch request type; must include `urn:ietf:params:scim:api:messages:2.0:PatchOp`.",
            "items": {
              "type": "string"
            }
          },
          "Operations": {
            "type": "array",
            "description": "List of PATCH operations to apply.",
            "items": {
              "type": "object",
              "required": [
                "op"
              ],
              "properties": {
                "op": {
                  "type": "string",
                  "enum": [
                    "add",
                    "remove",
                    "replace"
                  ]
                },
                "path": {
                  "type": "string",
                  "description": "SCIM attribute path to operate on."
                },
                "value": {
                  "description": "New value for `add` or `replace` operations."
                }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "AnaplanAuthToken": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Anaplan authentication token. Format: `AnaplanAuthToken {token}`"
      },
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      },
      "BasicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic authentication. Format: `Basic <base64(username:password)>`"
      }
    }
  }
}
