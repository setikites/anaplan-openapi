"\\\"\",\n\_\_\_\_\_ \"encoding\":\"UTF-8\",\n\_\_\_\_\_ \"exportFormat\":\"text/csv\",\n\_\_\_\_\_ \"headerNames\":[\n\_\_\_\_\_\_\_\_ \"ListWithSemiColonAsSeparator\",\n\_\_\_\_\_\_\_\_ \"Parent\",\n\_\_\_\_\_\_\_\_ \"Code\",\n\_\_\_\_\_\_\_\_ \"DepProjects\",\n\_\_\_\_\_\_\_\_ \"col1\",\n\_\_\_\_\_\_\_\_ \"col2\",\n\_\_\_\_\_\_\_\_ \"col3\",\n\_\_\_\_\_\_\_\_ \"col4\",\n\_\_\_\_\_\_\_\_ \"data\",\n\_\_\_\_\_\_\_\_ \"delete\"\n\_\_\_\_\_ ],\n\_\_\_\_\_ \"listNames\":[\n\_\_\_\_\_\_\_\_ \"\",\n\_\_\_\_\_\_\_\_ \"\",\n\_\_\_\_\_\_\_\_ \"\",\n\_\_\_\_\_\_\_\_ \"\"\n\_\_\_\_\_ ],\n\_\_\_\_\_ \"rowCount\":20432,\n\_\_\_\_\_ \"separator\":\",\"\n\_\_ }\n}\n```"
